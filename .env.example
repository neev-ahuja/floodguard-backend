# Flood Guard Backend Environment Variables
PORT=3001
NODE_ENV=development

# Supabase Configuration
# Project ID: abmahlurcmznbrnjmwmx
SUPABASE_URL=https://abmahlurcmznbrnjmwmx.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SECRET_KEY=your_supabase_service_role_secret_key_here

# Admin Portal Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
# To use hashed password in production, run 'node -e "console.log(require(\"bcrypt\").hashSync(\"your_password\", 10))"'
ADMIN_PASSWORD_HASH=
ALLOW_DEFAULT_ADMIN=true

# Security & Sessions
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=dev-session-secret-change-in-production-immediately

# Third-Party API Keys (Optional/Integrations)
GROQ_API_KEY=
BREVO_API_KEY=
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# App URLs
PUBLIC_APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
